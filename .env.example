# ===== Common =====
NODE_ENV=development

# ===== Server =====
PORT=3000
# Public base URL of the deployed app, used for generating QR codes
PUBLIC_BASE_URL=http://localhost:5173

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql://mealping:mealping@localhost:5432/mealping?schema=public

# ===== Auth =====
# Plain admin password for the lightweight single-admin login
ADMIN_PASSWORD=admin123
# JWT secret for signing admin tokens
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ===== Shop info =====
SHOP_NAME=MealPing 小馆

# ===== WeChat notification =====
# Channel: wechat_test_account | disabled
NOTIFY_CHANNEL=disabled
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TEMPLATE_ID=
WECHAT_ADMIN_OPENID=

# ===== Web (Vite) =====
# Leave empty to use Vite proxy (dev) / Nginx /api (prod). Set absolute URL only
# when the web app is served from a different origin than the API.
VITE_API_BASE_URL=
